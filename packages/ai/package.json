{
  "name": "@ams/ai",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers/*": {
      "types": "./dist/providers/*.d.ts",
      "default": "./dist/providers/*.js"
    },
    "./prompts/*": {
      "types": "./dist/prompts/*.d.ts",
      "default": "./dist/prompts/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "openai": "^4.50.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "pdf-parse": "^1.1.1"
  },
  "peerDependencies": {
    "@ams/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
