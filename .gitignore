# ============================================
# Pi (AI coding agent)
# ============================================
# Keep the configuration folder, but ignore any local API key overrides
# that an operator might drop in for custom providers (e.g. Conduit).
.pi/extensions/**/*.env
.pi/extensions/**/*.local
.pi/extensions/conduit/
.opencodeignore
.env
