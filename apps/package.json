{
  "name": "@ams/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "@hono/node-server": "^1.11.0",
    "drizzle-orm": "^0.31.0",
    "postgres": "^3.4.0",
    "@supabase/supabase-js": "^2.45.0",
    "zod": "^3.23.0",
    "openai": "^4.50.0",
    "dotenv": "^16.4.0"
  },
  "peerDependencies": {
    "@ams/shared": "workspace:*",
    "@ams/ai": "workspace:*"
  },
  "devDependencies": {
    "drizzle-kit": "^0.22.0",
    "tsx": "^4.15.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
